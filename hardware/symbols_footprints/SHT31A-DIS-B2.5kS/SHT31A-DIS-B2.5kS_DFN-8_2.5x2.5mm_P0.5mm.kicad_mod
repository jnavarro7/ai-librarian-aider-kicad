(footprint "SHT31A-DIS-B2.5kS_DFN-8_2.5x2.5mm_P0.5mm" (layer "F.Cu")
  (fp_text reference "REF**" (at 0 -2 0) (layer "F.SilkS"))
  (fp_text value "SHT31A-DIS-B2.5kS_DFN-8_2.5x2.5mm_P0.5mm" (at 0 2.5 0) (layer "F.Fab"))
  ; Outline Silkscreen
  (fp_line (start -1.35 1.35) (end 1.35 1.35)
    (stroke (width 0.12) (type solid))
    (layer "F.SilkS"))
  (fp_line (start 1.35 1.35) (end 1.35 -1.35)
    (stroke (width 0.12) (type solid))
    (layer "F.SilkS"))
  (fp_line (start 1.35 -1.35) (end -1.35 -1.35)
    (stroke (width 0.12) (type solid))
    (layer "F.SilkS"))
  (fp_line (start -1.35 -1.35) (end -1.35 1.35)
    (stroke (width 0.12) (type solid))
    (layer "F.SilkS"))
  ; Pin 1 indicator
  (fp_circle (center -1.65 -1.25) (end -1.53 -1.25)
    (stroke (width 0.12) (type solid)) (fill none)
    (layer "F.SilkS"))
  ; Fab Layer
  (fp_rect (start -1.25 1.25) (end 1.25 -1.25)
    (stroke (width 0.10) (type solid))
    (layer "F.Fab"))
  ; Courtyard
  (fp_rect (start -1.55 1.55) (end 1.55 -1.55)
    (stroke (width 0.05) (type solid))
    (layer "F.CrtYd"))
  ; Pads (left side: pads 1-4; right side: 5-8)
  (pad "1" smd rect (at -1.25 -0.75 0) (size 0.3 1.0) (layers "F.Cu" "F.Paste" "F.Mask"))
  (pad "2" smd rect (at -1.25 -0.25 0) (size 0.3 1.0) (layers "F.Cu" "F.Paste" "F.Mask"))
  (pad "3" smd rect (at -1.25 0.25 0) (size 0.3 1.0) (layers "F.Cu" "F.Paste" "F.Mask"))
  (pad "4" smd rect (at -1.25 0.75 0) (size 0.3 1.0) (layers "F.Cu" "F.Paste" "F.Mask"))
  (pad "5" smd rect (at 1.25 0.75 0) (size 0.3 1.0) (layers "F.Cu" "F.Paste" "F.Mask"))
  (pad "6" smd rect (at 1.25 0.25 0) (size 0.3 1.0) (layers "F.Cu" "F.Paste" "F.Mask"))
  (pad "7" smd rect (at 1.25 -0.25 0) (size 0.3 1.0) (layers "F.Cu" "F.Paste" "F.Mask"))
  (pad "8" smd rect (at 1.25 -0.75 0) (size 0.3 1.0) (layers "F.Cu" "F.Paste" "F.Mask"))
  ; Center pad
  (pad "9" smd rect (at 0 0 0) (size 1.8 1.1) (layers "F.Cu" "F.Paste" "F.Mask"))
)
